{"$schema": "testcase-config-schema-v2.json", "project": {"name": "电商订单管理系统", "code": "ECOM-ORDER", "auto_detect": true, "default_language": "zh-CN", "domain": "e-commerce"}, "pipeline": {"phases": ["input_preprocessing", "requirements", "code_analysis", "domain_modeling", "mbt_design", "testcase_generation"], "gate_strategy": "standard", "continue_on_warning": true, "stop_on_error": false, "max_retries_per_phase": 2}, "generation": {"output_format": "markdown", "testcase_naming": "TC-{phase}-{module}-{sequence:03d}", "priority_distribution": {"P0": 0.15, "P1": 0.25, "P2": 0.35, "P3": 0.25}, "boundary_analysis": {"method": "robust", "include_null": true, "include_empty": true, "include_special_chars": true, "include_unicode": true}, "deduplication": {"enabled": true, "similarity_threshold": 0.85, "method": "semantic"}, "max_testcases_per_module": 500}, "coverage": {"requirements_coverage_target": 100, "path_coverage_target": "critical+normal", "state_coverage_target": 100, "transition_coverage_target": 90, "boundary_coverage_target": 100, "defect_coverage_target": "all_critical_major"}, "quality": {"enable_gate_check": true, "strict_mode": false, "max_warnings_per_phase": 5, "hallucination_detection": true}, "output": {"directory": "./test-output/", "include_metadata": true, "include_traceability": true, "include_change_log": true, "compression": false, "separate_files_by_type": false, "include_executable_code": true}, "advanced": {"research_enabled": true, "research_queries_per_phase": 3, "model_optimization": {"state_merging_threshold": 0.9, "max_states_before_merge": 20, "abstraction_level": "balanced"}, "chaos_engineering": {"enabled": true, "scenarios": ["network_delay", "network_loss", "service_timeout", "resource_exhaustion"], "injection_probability": 0.1}, "mutation_testing": {"enabled": true, "operators": ["condition_replacement", "math_operator", "logical_negator", "boundary_change"], "mutation_score_threshold": 0.8}, "error_guessing": {"enabled": true, "c